# Backend
PORT=5000
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://catalog:catalog@localhost:5432/catalog
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=12h
NODE_ENV=development

# Google Drive (pick one auth method)
# Share the Drive folder with the service account client_email
GOOGLE_SERVICE_ACCOUNT_PATH=../raw-hair-wholesale-86af21403f6f.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_DRIVE_FOLDER_ID=
CATALOG_SYNC_INTERVAL_MINUTES=5

# Telegram bot
TELEGRAM_BOT_TOKEN=
# Optional bootstrap list (comma-separated). After first run, manage users in Admin → Telegram bot.
TELEGRAM_ALLOWED_USER_IDS=
DEFAULT_CATALOG_SLUG=lux-001
