# Copy to .env on the server before: docker compose up -d --build

# Postgres (used by docker-compose + backend)
POSTGRES_USER=catalog
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=catalog

# App
FRONTEND_URL=https://catalog.raw-hair-wholesale.com
JWT_SECRET=change-me-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=12h
NODE_ENV=production

# Google Drive
# Put service account JSON into ./secrets/google-service-account.json on the server
GOOGLE_SERVICE_ACCOUNT_PATH=/app/secrets/google-service-account.json
GOOGLE_DRIVE_FOLDER_ID=
CATALOG_SYNC_INTERVAL_MINUTES=30
DEFAULT_CATALOG_SLUG=hair-catalog

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
