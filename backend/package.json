{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "db:init:prod": "node dist/db/init.js",
    "dev": "ts-node-dev --respawn --transpile-only --files -r tsconfig-paths/register src/server.ts",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:init": "ts-node -r tsconfig-paths/register src/db/init.ts"
  },
  "dependencies": {
    "@catalog/shared": "*",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.2",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.16.0",
    "sharp": "^0.35.3",
    "telegraf": "^4.16.3",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.0",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.9.0",
    "typescript": "^5.7.3"
  }
}
